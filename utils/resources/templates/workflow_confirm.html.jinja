<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            padding: 0;
            width: fit-content;
            height: fit-content;
            background: transparent;
            font-family: "Segoe UI", Arial, sans-serif;
        }

        .workflow-confirm {
            width: 548px;
            padding: 24px 24px 10px;
            background: transparent;
        }

        .confirm-card {
            width: 500px;
            min-height: 560px;
            position: relative;
            background: transparent;
        }

        .cover {
            position: relative;
            height: 340px;
            overflow: hidden;
            background: #f1f5f9;
            border-radius: 30px;
            border: 1px solid rgba(15, 23, 42, 0.08);
            box-shadow: 0 16px 38px rgba(15, 23, 42, 0.2);
        }

        .cover img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .cover::after {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(
                to top,
                rgba(0, 0, 0, 0.72) 0%,
                rgba(0, 0, 0, 0.28) 48%,
                transparent 78%
            );
        }

        .action-label {
            position: absolute;
            top: 20px;
            right: 20px;
            z-index: 2;
            padding: 7px 14px;
            border-radius: 14px;
            background: rgba(255, 255, 255, 0.22);
            color: #ffffff;
            font-size: 12px;
            line-height: 1.2;
            font-weight: 900;
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.25);
            box-shadow: 0 8px 18px rgba(0, 0, 0, 0.18);
        }

        .type-badge {
            position: absolute;
            top: 20px;
            left: 20px;
            z-index: 2;
            padding: 7px 16px;
            border-radius: 13px;
            color: #ffffff;
            font-size: 12px;
            line-height: 1.2;
            font-weight: 900;
            border: 1px solid rgba(255, 255, 255, 0.25);
            box-shadow: 0 6px 16px rgba(0, 0, 0, 0.25);
        }

        .badge-live { background: linear-gradient(135deg, #fb7299, #ff8da1); }
        .badge-dyn { background: linear-gradient(135deg, #00a1d6, #33b5e5); }

        .identity {
            position: absolute;
            left: 28px;
            right: 28px;
            bottom: 26px;
            z-index: 2;
            color: #ffffff;
        }

        .username {
            font-size: 30px;
            line-height: 1.2;
            font-weight: 900;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            text-shadow: 0 2px 8px rgba(0, 0, 0, 0.55);
        }

        .uid {
            margin-top: 5px;
            font-size: 15px;
            color: rgba(255, 255, 255, 0.8);
            font-family: Consolas, monospace;
        }

        .content {
            padding: 20px 26px 6px;
        }

        .title {
            color: #ffffff;
            font-size: 24px;
            line-height: 1.25;
            font-weight: 900;
            text-shadow:
                0 3px 12px rgba(0, 0, 0, 0.86),
                0 0 2px rgba(0, 0, 0, 0.76);
        }

        .summary {
            margin-top: 9px;
            color: rgba(255, 255, 255, 0.9);
            font-size: 15px;
            line-height: 1.55;
            text-shadow:
                0 2px 8px rgba(0, 0, 0, 0.82),
                0 0 2px rgba(0, 0, 0, 0.75);
        }

        .actions {
            margin-top: 18px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .action-box {
            min-height: 72px;
            padding: 12px;
            border-radius: 16px;
            border: 1px solid rgba(255, 255, 255, 0.32);
        }

        .action-box strong {
            display: block;
            color: #ffffff;
            font-size: 13px;
            line-height: 1.2;
            font-weight: 900;
            text-shadow: 0 2px 8px rgba(0, 0, 0, 0.42);
        }

        .action-box span {
            display: block;
            margin-top: 7px;
            color: rgba(255, 255, 255, 0.96);
            font-size: 14px;
            line-height: 1.2;
            overflow-wrap: anywhere;
            text-shadow: 0 2px 8px rgba(0, 0, 0, 0.42);
        }

        .confirm { background: rgba(16, 185, 129, 0.52); }
        .cancel { background: rgba(244, 63, 94, 0.48); }
    </style>
</head>
<body>
    <div class="workflow-confirm">
        <div class="confirm-card">
            <div class="cover">
                <img src="{{ face }}" onerror="this.src='http://i0.hdslb.com/bfs/face/member/noface.jpg'">
                <div class="action-label">{{ action_label | default('待确认') }}</div>
                {% if sub_type == 'live' %}
                    <div class="type-badge badge-live">LIVE</div>
                {% else %}
                    <div class="type-badge badge-dyn">DYNAMIC</div>
                {% endif %}
                <div class="identity">
                    <div class="username">{{ username }}</div>
                    <div class="uid">UID: {{ uid }}</div>
                </div>
            </div>
            <div class="content">
                <div class="title">{{ title | default('确认订阅这个 UP 主吗？') }}</div>
                <div class="summary">{{ summary | default('确认后会写入当前会话订阅。') }}</div>
                <div class="actions">
                    <div class="action-box confirm">
                        <strong>确认</strong>
                        <span>{{ confirm_text }}</span>
                    </div>
                    <div class="action-box cancel">
                        <strong>取消</strong>
                        <span>{{ cancel_text }}</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
